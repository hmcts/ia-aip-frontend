{% set pageTitleName = i18n.pages.taskList.title %}
{% extends "layout.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{% block content %}
  <h1 class="govuk-heading-xl">{{ i18n.pages.taskList.header }}</h1>
  <ol class="task-list">
  {% for section in data %}
    <li>
      <h2 class="govuk-heading-m">{{ i18n.pages.taskList.sections[section.sectionId] }}</h2>
      <ul class="govuk-list">
        {% for task in section.tasks %}
          <li class="govuk-!-font-size-24 task-list__item">
            {% if task.active %}
              <a class="govuk-link" id='{{ i18n.pages.taskList[task.id].id }}'
                 href='{{ i18n.pages.taskList[task.id].path | path }}'
                 aria-describedby='{{ i18n.pages.taskList[task.id].id }}-status'>
                {{ i18n.pages.taskList[task.id].title }}
              </a>
            {% else %}
              <span id='{{ i18n.pages.taskList[task.id].id }}-label'>{{ i18n.pages.taskList[task.id].title }}</span>
            {% endif %}
            {% if task.completed %}
              <strong class="govuk-tag" id='{{ i18n.pages.taskList[task.id].id }}-status'>Saved</strong>
            {% else %}
              {% if task.active %}
                <strong class="govuk-tag govuk-tag--blue" id='{{ i18n.pages.taskList[task.id].id }}-status'>To do</strong>
              {% else %}
                <strong class="govuk-tag govuk-tag--grey" id='{{ i18n.pages.taskList[task.id].id }}-status' aria-labelledby='{{ i18n.pages.taskList[task.id].id }}-label {{ i18n.pages.taskList[task.id].id }}-status'>Cannot start yet</strong>
              {% endif %}
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </li>
  {% endfor %}
  </ol>
{% endblock %}
