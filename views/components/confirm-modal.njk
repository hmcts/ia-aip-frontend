{% macro confirmModal(modalId, modalTitle, modalDescription, modalButton) %}
  {% set confirmButtonId = modalId + '-confirm' %}
  {% set cancelButtonId = modalId + '-cancel' %}
  {% set titleId = modalId + '-title' %}
  {% set descriptionId = modalId + '-description' %}
  {% set overlayId = modalId + '-overlay' %}
  <div class="timeout-modal" id={{ modalId }} role="dialog" aria-labelledby="{{ titleId }}" aria-describedby="{{ descriptionId }}" aria-hidden="true">
    <h2 class="govuk-heading-l" id="{{ titleId }}">{{ modalTitle }}</h2>
    <p id="{{ descriptionId }}">{{ modalDescription }}</p>
    <div class="modal-buttons__container">
        {{ govukButton({
          text: modalButton,
          attributes: {
            id: confirmButtonId
          }
        }) }}

        {{ govukButton({
          text: 'Cancel',
          classes: "govuk-button--secondary",
          attributes: {
            id: cancelButtonId
          }
        }) }}
    </div>
  </div>
  <div class="modal-overlay" id="{{ overlayId }}" tabindex="-1" aria-hidden="true"></div>
{% endmacro %}
