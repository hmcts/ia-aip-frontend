{% set pageTitleName = i18n.pages.joinAppeal.title %}
{% extends "layout.njk" %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/fieldset/macro.njk" import govukFieldset %}

{% import "helpers/text-helpers.njk" as text %}

{% block content %}
  {% if errorList %}
    {{ govukErrorSummary({
      titleText: i18n.validationErrors.errorSummary,
      errorList: errorList
    }) }}
  {% endif %}
  {% call govukFieldset({
    legend: {
      text: i18n.pages.joinAppeal.title,
      classes: "govuk-fieldset__legend--xl",
      isPageHeading: true
    }
  }) %}
  <form action="{{ paths.nonLegalRep.joinAppeal }}" method="post" novalidate>
    <p>{{ i18n.pages.joinAppeal.instructions }}</p>
    <ul class="govuk-list govuk-list--bullet">
      <li>{{ i18n.pages.joinAppeal.partOne }}</li>
      <li>{{ i18n.pages.joinAppeal.partTwo }}</li>
      <li>{{ i18n.pages.joinAppeal.partThree }}</li>
     </ul>
    <p><strong>{{ i18n.pages.joinAppeal.instructionsPartTwo }}</strong></p>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    {{ govukInput({
      hint: {
        text: i18n.pages.joinAppeal.enterCaseReference.hintText
      },
      id: "caseReference",
      name: "caseReference",
      type: "text",
      value: caseReference,
      inputmode: "numeric",
      classes: "govuk-input--width-10",
      spellcheck: false,
      label: {
        text: i18n.pages.joinAppeal.enterCaseReference.label
      },
      errorMessage: {
        text: errors['caseReference'].text
      } if errors['caseReference']
    }) }}
    {{ govukInput({
      id: "joinAppealAccessCode",
      name: "joinAppealAccessCode",
      type: "text",
      value: joinAppealAccessCode,
      classes: "govuk-input--width-10",
      spellcheck: false,
      label: {
        text: i18n.pages.joinAppeal.enterAccessCode.label
      },
      errorMessage: {
        text: errors['joinAppealAccessCode'].text
      } if errors['joinAppealAccessCode']
    }) }}
    {{ saveButton({name: 'send', text: 'Join appeal'}) }}
  {% endcall %}
  </form>

  {{ contactUs() }}

{% endblock %}
